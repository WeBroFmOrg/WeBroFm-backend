# ── Django Core ──
SECRET_KEY=generate-a-secure-random-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
CORS_ALLOW_ALL=False

# ── Database (sqlite or postgres) ──
DB_ENGINE=postgres
DB_NAME=webrofm
DB_USER=webrofm
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432

# ── Cloudflare R2 ──
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# ── Redis ──
REDIS_URL=redis://127.0.0.1:6379/1

# ── CORS / CSRF ──
ALLOWED_ORIGINS=https://your-website.com,https://admin.your-website.com
CSRF_TRUSTED_ORIGINS=https://your-website.com,https://admin.your-website.com

# ── Twilio SMS (OTP) ──
TWILIO_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
ENABLE_DEV_LOGIN=false
DUMMY_PHONE=9999999999
DUMMY_OTP=123456
DUMMY_COUNTRY_CODE=+91

# ── Optional ──
# MEDIA_URL=https://r2-cdn.yourdomain.com/
