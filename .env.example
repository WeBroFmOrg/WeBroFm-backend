# ── Django Core ──
DEBUG=False
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=api.webrofm.in,localhost
ADMIN_URL=a8x9k2mz-admin/

# ── Database (set DB_ENGINE=postgres for production) ──
DB_ENGINE=sqlite
# DB_ENGINE=postgres
# DB_NAME=webrofm
# DB_USER=webrofm
# DB_PASSWORD=your_db_password
# DB_HOST=127.0.0.1
# DB_PORT=5432

# ── Cloudflare R2 Credentials ──
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET_NAME=webrofm
R2_ACCOUNT_ID=your_r2_account_id
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# ── Redis ──
REDIS_URL=redis://127.0.0.1:6379/1

# ── CORS / CSRF ──
ALLOWED_ORIGINS=https://admin.webrofm.in,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://admin.webrofm.in,http://localhost:3000
CORS_ALLOW_ALL=False

# ── MSG91 SMS (OTP) ──
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
COUNTRY_CODE=+91

# ── SSL / HSTS ──
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# ── Logging ──
LOG_FILE=/var/log/webrofm/django.log
